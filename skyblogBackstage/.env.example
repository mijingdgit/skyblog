# Django production environment template.
# Copy this file to .env on the server and replace the placeholder values.

SKYBLOG_SECRET_KEY=replace-with-a-long-random-secret-key
SKYBLOG_DEBUG=False

# Comma-separated hostnames that are allowed to serve this Django app.
# Example: skyblog.example.com,www.skyblog.example.com,127.0.0.1
SKYBLOG_ALLOWED_HOSTS=localhost,127.0.0.1

# Public frontend site URL. Used by robots.txt and sitemap.xml.
# Example: https://skyblog.example.com
SKYBLOG_SITE_URL=http://127.0.0.1:5173

# Comma-separated frontend origins allowed to call the API with credentials.
# Example: https://skyblog.example.com
SKYBLOG_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated trusted origins for Django CSRF checks.
# Example: https://skyblog.example.com
SKYBLOG_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SKYBLOG_CORS_ALLOW_CREDENTIALS=True
SKYBLOG_CSRF_COOKIE_SAMESITE=Lax
SKYBLOG_SESSION_COOKIE_SAMESITE=Lax

# Enable these only when the site is served through HTTPS.
SKYBLOG_SECURE_SSL_REDIRECT=False
SKYBLOG_SESSION_COOKIE_SECURE=False
SKYBLOG_CSRF_COOKIE_SECURE=False

# Enable this when Django is behind Nginx/Caddy/another HTTPS reverse proxy.
SKYBLOG_USE_X_FORWARDED_PROTO=False

# Extra production security headers.
# Enable HSTS only after HTTPS is confirmed stable for the whole site.
SKYBLOG_SECURE_HSTS_SECONDS=0
SKYBLOG_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SKYBLOG_SECURE_HSTS_PRELOAD=False
SKYBLOG_SECURE_CONTENT_TYPE_NOSNIFF=True
SKYBLOG_SECURE_REFERRER_POLICY=same-origin
SKYBLOG_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SKYBLOG_X_FRAME_OPTIONS=DENY
SKYBLOG_SESSION_COOKIE_HTTPONLY=True

# Upload limits, in bytes.
SKYBLOG_DATA_UPLOAD_MAX_MEMORY_SIZE=20971520
SKYBLOG_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

SKYBLOG_STATIC_URL=/static/
SKYBLOG_STATIC_ROOT=staticfiles
SKYBLOG_MEDIA_URL=/media/
SKYBLOG_MEDIA_ROOT=media
