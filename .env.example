# Frontend environment variables for Vite.
# Copy this file to .env.production or .env.local and adjust values for your deployment.

# If the Vue site and Django API are served from the same domain, keep this empty.
# Example for separated deployment: https://api.example.com
VITE_API_BASE_URL=

# Django admin address used by /admin and /login redirects.
# Same-domain deployment can use /admin/.
VITE_DJANGO_ADMIN_URL=/admin/
